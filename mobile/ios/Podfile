# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

require File.join(File.dirname(`node --print "require.resolve('expo/package.json', { paths: ['#{__dir__}/..'] })"`), "scripts/autolinking")

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Required for Firebase Swift pods (Auth, Database, CoreInternal)
pod 'GoogleUtilities', :modular_headers => true
pod 'FirebaseAppCheckInterop', :modular_headers => true
pod 'FirebaseAuthInterop', :modular_headers => true
pod 'RecaptchaInterop', :modular_headers => true
pod 'leveldb-library', :modular_headers => true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Cashflow' do
  use_expo_modules!
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix fmt 11.0.2 consteval errors with Xcode 26.4 Clang
    # Patch fmt prefix header to disable consteval before any fmt header is included
    fmt_pch = File.join(installer.sandbox.root, 'Target Support Files', 'fmt', 'fmt-prefix.pch')
    if File.exist?(fmt_pch)
      content = File.read(fmt_pch)
      unless content.include?('FMT_USE_CONSTEVAL')
        File.write(fmt_pch, "#define FMT_USE_CONSTEVAL 0\n" + content)
      end
    end
    # Also patch the base.h header directly as fmt is included from many other pods
    # Disable consteval for all Apple clang — broken in Xcode 26.4
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      unless content.include?('// Xcode 26.4 fix')
        FileUtils.chmod(0644, fmt_base)
        content.sub!(
          '#elif defined(__cpp_consteval)',
          "// Xcode 26.4 fix: consteval is broken in Apple clang shipped with Xcode 26.4\n#elif defined(__apple_build_version__)\n#  define FMT_USE_CONSTEVAL 0\n#elif defined(__cpp_consteval)"
        )
        File.write(fmt_base, content)
      end
    end

    # Fix Firebase 12.x: FirebaseAuth-Swift.h is generated in DerivedData but
    # RNFBMessaging/RNFBDatabase need it via <FirebaseAuth/FirebaseAuth-Swift.h>.
    # Copy it from DerivedData (previous build) into the Pods headers directory.
    # On first build, a stub is created; running `pod install` after first build
    # will copy the real header.
    auth_header_dir = File.join(installer.sandbox.root, 'Headers', 'Private', 'FirebaseAuth')
    auth_swift_header = File.join(auth_header_dir, 'FirebaseAuth-Swift.h')
    FileUtils.mkdir_p(auth_header_dir)

    # Try to find the real generated header from DerivedData
    derived_data = File.expand_path('~/Library/Developer/Xcode/DerivedData')
    real_header = Dir.glob(File.join(derived_data, 'Cashflow-*/Build/Products/*/FirebaseAuth/Swift Compatibility Header/FirebaseAuth-Swift.h')).first
    if real_header && File.exist?(real_header)
      FileUtils.cp(real_header, auth_swift_header)
    elsif !File.exist?(auth_swift_header)
      # Create minimal stub for first build — will fail but generate the real header
      File.write(auth_swift_header, "// Stub — run `pod install` again after first build\n")
    end
  end
end
